*{
  margin: 0;
  padding: 0;
  box-sizing: border-box
}

.fundoGrad{
  background-color: #0f3932;
  height: 100px;
  padding: 14px;
}

body{
  background-image:
  linear-gradient(rgba(255,255,255,0.3), rgba(255,255,255,0.3)),
  url("images/fundo-site2.png");
}

.fotoPrincipal img{
  width: 190px;
  border-radius: 40px;
  padding: 3%;
  margin-top: 10%;
  border-color: #ffffff;
  box-shadow: 2px 0 0 10px #555 solid;
  display: flex;
}

.title h1{
  color: #ffffffdf;
  font-size: 31px;
  text-align: center;
  font-family: Verdana;
}

.title p{
  color: #ffffffdf;
  text-align: center;
  justify-content: center;
  font-size: 13px;
  font-weight: bold;
  font-family: Verdana;
}

.title::after{
  content:"";
  display:block;
  width:200px;
  height:4px;
  background:#66b5a5;
  margin:10px auto 0;
  border-radius:2px;
}

.apresentacao{
  background-color: white;
  border-radius: 15px;
  display: flex;
  margin-left: 49%;
  margin-top: -38%;
  max-width:180px;
  box-shadow: 0px 7px 20px rgb(0,0,0);
}

.apresentacao p{
  color: #125e51;
  font-size: 14px;
  text-align: center;
  padding: 10px;
  font-weight: 600;
  font-family: Verdana;
}

.fundoGrad2{
  background-color: #0f3932;
  margin-top: 90px;
  height: 250px;
}

.title2 h1{
  color: #ffffffdf;
  font-size: 30px;
  text-align: center;
  padding: 10px;
  font-family: Verdana;
}

.title2 h1::after{
  content:"";
  display:block;
  width:80px;
  height:4px;
  background:#66b5a5;
  margin:5px auto 0;
  border-radius:2px;
}

.sobremim{
  background-color: white;
  padding: 10px;
  display: flex;
  width: 350px;
  height: 160px;
  border-radius: 15px;
  margin-left: 3%;
  margin-top: 0%;
  box-shadow: 0px 8px 15px rgb(0,0,0);
}

.sobremim img{
  width: 300px;
  border-radius: 15px;
}

.sobremim p{
  color:#125e51;
  font-size: 10px;
  font-weight: 650;
  padding: 2px;
  line-height: 15px;
  text-align: center;
  font-family: Verdana;
}

.textoArea{
  background-color: #7ad9bc;
  margin-top: 20px;
  height: 70px;
}

.textoArea h1{
  color: white;
  text-align: center;
  font-size: 22px;
  padding: 7px;
  font-family: Verdana;
}

.textoArea h1::after{
  content:"";
display:block;
width:80px;
height:4px;
background:#66b5a5;
margin: 4px auto 0;
border-radius:2px;
}

.cardArea{
  background-color: white;
  margin: 10px;
  display: flex;
  padding: 10px;
  width: 350px;
  margin-left: 4%;
  border-radius: 15px;
  box-shadow: 0px 6px 20px rgb(0,0,0);
}

.cardArea img{
  width: 170px;
  border-radius: 15px;
}

.cardArea h1{
  color: #75d8bc;
  font-size: 25px;
  font-weight: 600;
  padding: 5px;
  font-family: Verdana;
}

.cardArea p{
  font-weight: 700;
  padding: 5px;
  font-size: 11px;
  color: #125e51;
  font-family: Verdana;
}

.cuidados{
  background-color: #7ad9bc;
  height: 60px;
}

.cuidados h1{
  color: white;
  text-align: center;
  font-size: 22px;
  padding: 14px;
  font-family: Verdana;
}

.cuidados h1::after{
  content:"";
display:block;
width:80px;
height:4px;
background:#66b5a5;
margin:10px auto 0;
border-radius:2px;
}

.cardCuidados{
  background-color: white;
  margin: 10px;
  display: flex;
  flex-direction: column;
  padding: 10px;
  width: 180px;
  margin-left: 4%;
  border-radius: 15px;
  min-width: 280px;

border-radius: 20px;
min-width: 80%;
flex-shrink: 0;

scroll-snap-align: start;
box-shadow: 0 10px 25px rgba(0,0,0,0.2);

scroll-snap-align: start;
  box-shadow: 0px 6px 20px rgb(0,0,0);
}

.cardCuidados img{
  width: 150px;
  border-radius: 15px;
}

.textoCuidado h1{
  color: #75d8bc;
  font-size: 25px;
  font-weight: 600;
  padding: 5px;
  font-family: Verdana;
}

.textoCuidado p{
  font-weight: 700;
  padding: 5px;
  font-size: 11px;
  color: #125e51;
  font-family: Verdana;
}

.orgCards{
display: flex;
gap: 20px;

overflow-x: auto;
scroll-snap-type: x mandatory;

padding-left: 20px;
padding-right: 20px;
}

.orgCards::-webkit-scrollbar{
display:none;
}

.glass-box{
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  
  border-radius: 20px;
  padding: 25px;
  
  border: 1px solid rgba(255,255,255,0.2);
  
  color: white;
  text-align: center;
  
  box-shadow: 0 8px 32px rgba(0,0,0,0.2);
  margin: 20px;
}

.glass-box p{
  font-weight: 700;
  font-size: 20px;
  text-align: center;
  padding: 10px;
  font-family: Verdana;
}

.btn-instagram{
display:inline-block;
background:linear-gradient(45deg,#fd1d1d,#e1306c,#c13584);
color:white;
padding:17px 29px;
border-radius:12px;
text-decoration:none;
font-weight:bold;
box-shadow:0 5px 15px rgba(0,0,0,0.2);
transition:0.3s;
font-family: Verdana;
}

.btn-instagram:hover{
transform:scale(1.05);
}

.rodape{
  background-color: #125e51;
  height: 50px;
}

.rodape p{
  text-align: center;
  font-size: 17px;
  font-weight: 700;
  padding: 10px;
  color: white;
  font-family: Verdana;
}

/* animação inicial */
.reveal{
opacity:0;
transform: translateY(40px);
transition: all 0.8s ease;
}

/* quando aparece */
.reveal.active{
opacity:1;
transform: translateY(0);
}

@media (min-width:768px){

.apresentacao1{
display:flex;
align-items:center;
justify-content:center;
gap:40px;
}

.apresentacao{
margin:0;
max-width:300px;
}

.sobremim{
width:500px;
margin:auto;
}

.areasVet{
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
}

.cardArea{
width:350px;
}

.orgCards{
justify-content:center;
}

.cardCuidados{
min-width:300px;
max-width:320px;
}

}